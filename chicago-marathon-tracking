-- Chicago Marathon 2026: Goal Execution Plan
-- Target: 03:20:00 (Full Marathon)

WITH Current_Baseline AS (
    SELECT 
        'Madrid Half Marathon' AS race,
        '01:32:00'::INTERVAL AS finish_time,
        21.0975 AS distance_km
),
Goal_Metrics AS (
    SELECT 
        'Chicago Marathon' AS goal_race,
        '03:20:00'::INTERVAL AS target_time,
        42.195 AS distance_km
)
SELECT 
    g.goal_race,
    g.target_time,
    -- Calculate Required Pace per KM
    TRUNC(EXTRACT(EPOCH FROM g.target_time) / g.distance_km / 60, 2) AS target_pace_per_km,
    -- Calculate Required Pace per Mile
    TRUNC(EXTRACT(EPOCH FROM g.target_time) / 26.2 / 60, 2) AS target_pace_per_mile,
    -- Calculate "The Gap": Comparison to Madrid Half Marathon Pace
    TRUNC((EXTRACT(EPOCH FROM b.finish_time) / b.distance_km / 60) - 
          (EXTRACT(EPOCH FROM g.target_time) / g.distance_km / 60), 2) AS pace_variance_needed
FROM Goal_Metrics g, Current_Baseline b;

